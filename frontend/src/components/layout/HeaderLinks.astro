---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/market', label: 'Market' },
  { href: '/brands', label: 'Brands' },
  { href: '/series', label: 'Series' },
];
---

<nav class="nav-links">
  <ul>
    {
      links.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <li>
            <a href={link.href} class={`nav-link ${isActive ? 'active' : ''}`}>
              {link.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .nav-links ul {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link.active {
    color: var(--text-primary);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--brand-primary);
    border-radius: 2px;
  }
</style>
