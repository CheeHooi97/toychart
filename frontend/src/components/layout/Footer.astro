---
const year = new Date().getFullYear();
---

<footer class="app-footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <div class="logo">
        <span class="logo-icon">🧸</span>
        <span class="logo-text">toychart</span>
      </div>
      <p class="tagline text-secondary">
        Track the market value of your favorite collectibles. Pop Mart, Funko,
        and more.
      </p>
    </div>

    <div class="footer-links">
      <div class="link-group">
        <h4 class="text-primary">Market</h4>
        <ul>
          <li><a href="/brands">Brands</a></li>
          <li><a href="/series">Series</a></li>
          <li><a href="/trending">Trending Items</a></li>
        </ul>
      </div>
      <div class="link-group">
        <h4 class="text-primary">Portfolio</h4>
        <ul>
          <li><a href="/portfolio">My Collection</a></li>
          <li><a href="/watchlists">Watchlists</a></li>
          <li><a href="/alerts">Price Alerts</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p class="text-tertiary">
        © {year} toychart. All rights reserved. Data sourced from secondary markets.
      </p>
    </div>
  </div>
</footer>

<style>
  .app-footer {
    border-top: 1px solid var(--border-color);
    background: var(--bg-secondary);
    padding-top: 4rem;
    margin-top: 4rem;
  }

  .footer-content {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
    justify-content: space-between;
    margin-bottom: 4rem;
  }

  .footer-brand {
    max-width: 320px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .logo-icon {
    transform: rotate(-10deg);
  }

  .tagline {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .text-secondary {
    color: var(--text-secondary);
  }

  .footer-links {
    display: flex;
    gap: 4rem;
  }

  .link-group h4 {
    font-weight: 600;
    margin-bottom: 1.5rem;
    font-family: 'Outfit', sans-serif;
  }

  .link-group ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .link-group a {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .link-group a:hover {
    color: var(--brand-primary);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding: 1.5rem 0;
    background: var(--bg-primary);
  }

  .text-tertiary {
    color: var(--text-tertiary);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .footer-links {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
