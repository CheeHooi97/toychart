---
import TrendBadge from './TrendBadge.astro';

export interface Props {
  id: string;
  name: string;
  series: string;
  price: string;
  trend: 'up' | 'down' | 'neutral';
  trendValue: string;
  imageUrl: string;
  rarity?: string;
  rank?: number;
}

const {
  id,
  name,
  series,
  price,
  trend,
  trendValue,
  imageUrl,
  rarity = 'Common',
  rank,
} = Astro.props;

const rarityColors: Record<string, string> = {
  Common: '#a1a1aa',
  Exclusive: '#3b82f6',
  Chase: '#8b5cf6',
  Secret: '#f59e0b',
};
---

<a href={`/item/${id}`} class="collectible-card glass-panel fade-in">
  {rank && <div class="rank-badge">#{rank}</div>}

  <div class="card-image-wrap">
    <div class="image-overlay"></div>
    <!-- Simple placeholder image that doesn't 404 -->
    {
      imageUrl ? (
        <img src={imageUrl} alt={name} loading="lazy" />
      ) : (
        <div class="image-fallback">🧸</div>
      )
    }

    {
      rarity !== 'Common' && (
        <div
          class="rarity-badge"
          style={`color: ${rarityColors[rarity] || 'white'}; border-color: ${rarityColors[rarity] || 'white'}40; background: ${rarityColors[rarity]}15`}
        >
          {rarity}
        </div>
      )
    }
  </div>

  <div class="card-content">
    <div class="card-header">
      <p class="series-name">{series}</p>
      <h3 class="item-name">{name}</h3>
    </div>

    <div class="card-footer">
      <div class="price-container">
        <span class="price-label">Market Value</span>
        <span class="price-value">{price}</span>
      </div>
      <TrendBadge trend={trend} value={trendValue} />
    </div>
  </div>
</a>

<style>
  .collectible-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s ease,
      border-color 0.3s ease;
    height: 100%;
  }

  .collectible-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.5);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .rank-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 10;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(4px);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .card-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--bg-secondary);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-fallback {
    font-size: 4rem;
    opacity: 0.5;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 10, 0.6) 0%,
      transparent 40%
    );
    z-index: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .collectible-card:hover .image-overlay {
    opacity: 1;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .collectible-card:hover img {
    transform: scale(1.05);
  }

  .rarity-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 10;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    border: 1px solid;
    backdrop-filter: blur(4px);
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    justify-content: space-between;
    gap: 1rem;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .series-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .item-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  .price-container {
    display: flex;
    flex-direction: column;
  }

  .price-label {
    font-size: 0.65rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.1rem;
  }

  .price-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: 'Outfit', sans-serif;
  }
</style>
