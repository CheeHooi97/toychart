---
import Layout from '../../layouts/Layout.astro';
import PriceChart from '../../components/ui/PriceChart.tsx';
import TrendBadge from '../../components/ui/TrendBadge.astro';

// Dummy data
const item = {
  name: 'Chestnut Cocoa (Secret)',
  series: 'Labubu Exciting Macaron',
  brand: 'Pop Mart',
  releaseDate: '2023-10-15',
  rarity: 'Secret',
  odds: '1/72',
  retailPrice: '$15.99',
  imageUrl:
    'https://imagedelivery.net/j3cQhHk0Y2fW12f0X0X0Xw/placeholder-5/public',
  stats: {
    marketValue: '$185.00',
    trend: 'up' as const,
    trendPercent: '+12.5%',
    trend30d: '+45.0%',
    volatility: 'High',
    sales30d: 42,
  },
};

const recentSales = [
  {
    date: 'Oct 24, 2023',
    price: '$185.00',
    condition: 'Sealed',
    platform: 'eBay',
  },
  {
    date: 'Oct 22, 2023',
    price: '$180.00',
    condition: 'Open Box',
    platform: 'Mercari',
  },
  {
    date: 'Oct 18, 2023',
    price: '$195.00',
    condition: 'Sealed',
    platform: 'eBay',
  },
  {
    date: 'Oct 15, 2023',
    price: '$175.00',
    condition: 'Sealed',
    platform: 'eBay',
  },
  {
    date: 'Oct 10, 2023',
    price: '$160.00',
    condition: 'Open Box',
    platform: 'StockX',
  },
];

// Placeholder chart data
const chartData = [120, 125, 118, 135, 142, 150, 145, 160, 165, 175, 172, 185];
const chartLabels = [
  'Nov',
  'Dec',
  'Jan',
  'Feb',
  'Mar',
  'Apr',
  'May',
  'Jun',
  'Jul',
  'Aug',
  'Sep',
  'Oct',
];

export function getStaticPaths() {
  return [{ params: { id: 'lb-macaron-secret' } }];
}
---

<Layout title={`${item.name} | ${item.series} | Market Price`}>
  <div class="container page-layout">
    <div class="breadcrumbs slide-up">
      <a href="/brands">Brands</a>
      <span class="separator">/</span>
      <a href="/brands/pop-mart">{item.brand}</a>
      <span class="separator">/</span>
      <a href="/collection/labubu-exciting-macaron">{item.series}</a>
      <span class="separator">/</span>
      <span class="current">{item.name}</span>
    </div>

    <div class="item-grid">
      <!-- Left Column: Images & Meta -->
      <div class="item-sidebar fade-in">
        <div class="image-showcase glass-panel">
          <div class="rarity-badge">
            <span class="rarity-dot"></span>
            {item.rarity}
          </div>
          {/* Fallback image view */}
          <div class="image-inner">
            <span class="image-fallback-icon">🧸</span>
          </div>
        </div>

        <div class="item-specs glass-panel">
          <h3 class="specs-title">Item Details</h3>
          <ul class="specs-list">
            <li>
              <span class="spec-label">Brand</span>
              <span class="spec-value">{item.brand}</span>
            </li>
            <li>
              <span class="spec-label">Series</span>
              <span class="spec-value">{item.series}</span>
            </li>
            <li>
              <span class="spec-label">Release</span>
              <span class="spec-value">{item.releaseDate}</span>
            </li>
            <li>
              <span class="spec-label">Retail Price</span>
              <span class="spec-value">{item.retailPrice}</span>
            </li>
            <li>
              <span class="spec-label">Odds</span>
              <span class="spec-value">{item.odds}</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Right Column: Pricing & Data -->
      <div class="item-main fade-in" style="animation-delay: 0.1s;">
        <div class="item-header">
          <h1 class="item-title">{item.name}</h1>
          <p class="item-subtitle">{item.series}</p>
        </div>

        <div class="price-dashboard glass-panel">
          <div class="price-header">
            <span class="price-label">Estimated Market Value</span>
            <span class="update-time">Updated 2h ago</span>
          </div>

          <div class="condition-prices">
            <div class="condition-col">
              <span class="cond-label">Loose</span>
              <span class="cond-val text-primary">--</span>
            </div>
            <div class="condition-col active">
              <span class="cond-label">Open Box / CIB</span>
              <span class="cond-val">{item.stats.marketValue}</span>
              <div class="cond-trend">
                <TrendBadge
                  trend={item.stats.trend}
                  value={item.stats.trendPercent}
                />
              </div>
            </div>
            <div class="condition-col">
              <span class="cond-label">New / Sealed</span>
              <span class="cond-val text-primary">$195.00</span>
            </div>
          </div>

          <div class="price-metrics">
            <div class="metric">
              <span class="metric-label">30d Change</span>
              <span class="metric-value text-up">{item.stats.trend30d}</span>
            </div>
            <div class="metric">
              <span class="metric-label">Volatility</span>
              <span class="metric-value">{item.stats.volatility}</span>
            </div>
            <div class="metric">
              <span class="metric-label">30d Sales</span>
              <span class="metric-value">{item.stats.sales30d}</span>
            </div>
          </div>
          <div class="action-buttons">
            <button class="btn btn-primary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 5v14"></path><path d="M5 12h14"></path></svg
              >
              Add to Portfolio
            </button>
            <button class="btn btn-secondary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
                ></path></svg
              >
              Watchlist
            </button>
          </div>
        </div>

        <div class="chart-section fade-in" style="animation-delay: 0.2s;">
          <PriceChart client:load dataPoints={chartData} labels={chartLabels} />
        </div>

        <div class="sales-history fade-in" style="animation-delay: 0.3s;">
          <h3 class="section-title">Recent Sales</h3>
          <div class="table-container glass-panel">
            <table class="sales-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Sale Price</th>
                  <th>Condition</th>
                  <th>Platform</th>
                </tr>
              </thead>
              <tbody>
                {
                  recentSales.map((sale) => (
                    <tr>
                      <td>{sale.date}</td>
                      <td class="font-bold">{sale.price}</td>
                      <td>
                        <span class="condition-badge">{sale.condition}</span>
                      </td>
                      <td>{sale.platform}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <div class="view-more-container">
            <a href="#" class="view-more">View All Sales History →</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-layout {
    padding-top: 2rem;
  }

  .breadcrumbs {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
    margin-bottom: 2rem;
  }

  .breadcrumbs a:hover {
    color: var(--brand-primary);
  }

  .separator {
    color: var(--border-color);
  }

  .current {
    color: var(--text-primary);
  }

  .item-grid {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 3rem;
  }

  .image-showcase {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .image-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(
      circle at center,
      rgba(139, 92, 246, 0.15) 0%,
      transparent 70%
    );
  }

  .image-fallback-icon {
    font-size: 8rem;
    opacity: 0.8;
    filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.3));
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .rarity-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(245, 158, 11, 0.15);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: #fbd38d;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .rarity-dot {
    width: 6px;
    height: 6px;
    background: #f59e0b;
    border-radius: 50%;
    box-shadow: 0 0 8px #f59e0b;
  }

  .item-specs {
    padding: 1.5rem;
  }

  .specs-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    font-family: 'Outfit', sans-serif;
  }

  .specs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .specs-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1rem;
  }

  .specs-list li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .spec-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .spec-value {
    color: var(--text-primary);
    font-weight: 500;
    font-size: 0.95rem;
    text-align: right;
  }

  /* Right column */
  .item-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .item-header {
    margin-bottom: 0.5rem;
  }

  .item-title {
    font-family: 'Outfit', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #fff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .item-subtitle {
    font-size: 1.25rem;
    color: var(--brand-primary);
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
  }

  .price-dashboard {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .price-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .price-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .update-time {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .condition-prices {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.5rem;
  }

  .condition-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .condition-col:hover {
    background: var(--hover-overlay);
  }

  .condition-col.active {
    background: var(--bg-secondary);
    box-shadow: 0 0 0 1px var(--brand-primary);
  }

  .cond-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .cond-val {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .cond-trend {
    margin-top: 0.5rem;
  }

  .price-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-label {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric-value {
    font-size: 1.25rem;
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
  }

  .text-up {
    color: var(--trend-up);
  }

  .action-buttons {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
  }

  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--brand-primary);
    color: white;
    border: none;
    box-shadow: 0 4px 14px 0 rgba(59, 130, 246, 0.39);
  }

  .btn-primary:hover {
    background: var(--brand-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.23);
  }

  .btn-secondary {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--bg-tertiary);
    border-color: var(--text-secondary);
  }

  .section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .table-container {
    overflow-x: auto;
  }

  .sales-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .sales-table th {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1rem;
    border-bottom: 1px solid var(--border-color);
    font-weight: 600;
  }

  .sales-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.95rem;
  }

  .sales-table tr:last-child td {
    border-bottom: none;
  }

  .sales-table tr:hover td {
    background: rgba(255, 255, 255, 0.02);
  }

  .font-bold {
    font-weight: 700;
    font-family: 'Outfit', sans-serif;
  }

  .condition-badge {
    background: var(--bg-secondary);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    border: 1px solid var(--border-color);
  }

  .view-more-container {
    margin-top: 1rem;
    text-align: right;
  }

  .view-more {
    color: var(--brand-primary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .view-more:hover {
    color: var(--brand-accent);
  }

  @media (max-width: 900px) {
    .item-grid {
      grid-template-columns: 1fr;
    }

    .image-showcase {
      max-width: 400px;
      margin: 0 auto 1.5rem;
    }

    .action-buttons {
      grid-template-columns: 1fr;
    }
  }
</style>
