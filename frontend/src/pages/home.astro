---
import Layout from '../layouts/Layout.astro';
import Search from '../components/ui/Search.astro';
import { POPMART_SERIES, classifyPopmartSeries, sanitizePopmartTitle } from '../lib/popmartSeries';

type PopmartHotApiItem = {
  item: string;
  series: string;
  price: string;
  soldAt: string;
  href?: string;
};

type PopMartRow = {
  item: string;
  series: string;
  price: string;
  soldAt: string;
  href: string;
};

const formatUsd = (value?: string) => {
  const trimmed = (value ?? '').trim();
  if (!trimmed) {
    return '--';
  }
  return trimmed.startsWith('$') ? trimmed : `$${trimmed}`;
};

const formatSoldAt = (value?: string) => {
  const trimmed = (value ?? '').trim();
  if (!trimmed) {
    return '--';
  }
  const cleaned = trimmed.replace(/^Sold\s+/i, '').replace(/\s+/g, ' ');
  const dateMatch = cleaned.match(/^([A-Za-z]{3})\s+(\d{1,2}),?\s*(\d{4})$/);
  if (dateMatch) {
    const [, month, day, year] = dateMatch;
    return `${month} ${day.padStart(2, '0')} ${year}`;
  }
  return cleaned;
};

const splitSoldAt = (value: string) => {
  const dateMatch = value.match(/^([A-Za-z]{3}\s+\d{2})\s+(\d{4})$/);
  if (!dateMatch) {
    return null;
  }
  return { top: dateMatch[1], year: dateMatch[2] };
};

const popmartIpLabels: Record<string, string> = {
  labubu: 'labubu',
  skullpanda: 'skullpanda',
  dimoo: 'dimoo',
  hirono: 'hirono',
  molly: 'molly',
  crybaby: 'crybaby',
  pucky: 'pucky',
  hacipupu: 'hacipupu',
};

const escapeRegExp = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

const normalizeToken = (value: string) =>
  sanitizePopmartTitle(value)
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, ' ')
    .trim();

const detectPopmartIpSlug = (title: string) => {
  const normalized = normalizeToken(title);
  if (normalized.includes('skullpanda')) return 'skullpanda';
  if (normalized.includes('dimoo')) return 'dimoo';
  if (normalized.includes('hirono')) return 'hirono';
  if (normalized.includes('molly')) return 'molly';
  if (normalized.includes('crybaby')) return 'crybaby';
  if (normalized.includes('pucky')) return 'pucky';
  if (normalized.includes('hacipupu')) return 'hacipupu';
  return 'labubu';
};

const matchExcitingMacaronName = (rawTitle: string) => {
  const title = normalizeToken(rawTitle);
  if (!title) return '';
  if (title.includes('chestnut cocoa')) return 'Chestnut Cocoa (Secret)';
  if (title.includes('lychee berry')) return 'Lychee Berry';
  if (title.includes('green grape')) return 'Green Grape';
  if (title.includes('sea salt coconut') || title.includes('sea salt')) return 'Sea Salt Coconut';
  if (title.includes('toffee')) return 'Toffee';
  if (title.includes('sesame bean') || title.includes('sesame')) return 'Sesame Bean';
  if (title.includes('soymilk') || title.includes('soy milk')) return 'Soymilk';
  return '';
};

const matchHaveASeatName = (rawTitle: string) => {
  const title = normalizeToken(rawTitle);
  if (!title) return '';
  if (title.includes('duoduo') || title.includes('duo duo')) return 'Duoduo (Secret)';
  if (title.includes('baba')) return 'Baba';
  if (title.includes('sisi')) return 'Sisi';
  if (title.includes('ququ')) return 'Ququ';
  if (title.includes('dada')) return 'Dada';
  if (title.includes('zizi')) return 'Zizi';
  if (title.includes('hehe')) return 'Hehe';
  return '';
};

const compactPopmartItemTitle = (rawTitle: string, ipSlug: string, series: string) => {
  if (series === 'THE MONSTERS - Exciting Macaron Vinyl Face') {
    return matchExcitingMacaronName(rawTitle) || '';
  }
  if (series === 'THE MONSTERS - Have a Seat Series') {
    return matchHaveASeatName(rawTitle) || '';
  }

  let cleaned = sanitizePopmartTitle(rawTitle);
  cleaned = cleaned.replace(/\bpop\s*mart\b/gi, '');
  cleaned = cleaned.replace(/\bthe\s+monsters\b/gi, 'THE MONSTERS');
  cleaned = cleaned.replace(/\blabubu\b/gi, '');
  cleaned = cleaned.replace(/\b(authentic|official|genuine|new|sealed|in\s*hand|instock|open\s*box|opened|us\s*seller|free\s*shipping|blind\s*box|figure|vinyl|plush|pendant|toy|collectible)\b/gi, '');
  cleaned = cleaned.replace(/-/g, ' ');
  cleaned = cleaned.replace(/\s+/g, ' ').trim();

  const ipName = popmartIpLabels[ipSlug] ?? ipSlug;
  if (ipName) {
    cleaned = cleaned.replace(new RegExp(`\\b${escapeRegExp(ipName)}\\b`, 'gi'), '');
  }
  if (series) {
    cleaned = cleaned.replace(new RegExp(`\\b${escapeRegExp(series)}\\b`, 'gi'), '');
  }
  cleaned = cleaned.replace(/\s+/g, ' ').trim();
  return cleaned;
};

const popmartItemSlug = (series: string, title: string) => {
  if (series === 'THE MONSTERS - Exciting Macaron Vinyl Face') {
    const matched = title || matchExcitingMacaronName(title);
    const mapped: Record<string, string> = {
      Soymilk: 'soymilk',
      'Lychee Berry': 'lychee-berry',
      'Green Grape': 'green-grape',
      'Sea Salt Coconut': 'sea-salt-coconut',
      Toffee: 'toffee',
      'Sesame Bean': 'sesame-bean',
      'Chestnut Cocoa (Secret)': 'chestnut-cocoa',
    };
    if (mapped[matched]) return mapped[matched];
  }
  if (series === 'THE MONSTERS - Have a Seat Series') {
    const matched = title || matchHaveASeatName(title);
    const mapped: Record<string, string> = {
      Baba: 'baba',
      Sisi: 'sisi',
      Ququ: 'ququ',
      Dada: 'dada',
      Zizi: 'zizi',
      Hehe: 'hehe',
      'Duoduo (Secret)': 'duoduo',
    };
    if (mapped[matched]) return mapped[matched];
  }
  return title
    .toLowerCase()
    .replace(/&/g, ' and ')
    .replace(/\([^)]*\)/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
};

const popmartSeriesSlug = (series: string) => {
  if (series.toLowerCase().includes('exciting macaron')) {
    return 'labubu-exciting-macaron';
  }
  return series
    .toLowerCase()
    .replace(/&/g, ' and ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');
};

const toPopmartItemHref = (rawTitle: string, seriesOverride?: string) => {
  const safeTitle = sanitizePopmartTitle(rawTitle);
  const series = seriesOverride || classifyPopmartSeries(safeTitle);
  const ip = detectPopmartIpSlug(safeTitle);
  const compactTitle = compactPopmartItemTitle(safeTitle, ip, series) || safeTitle;
  const item = popmartItemSlug(series, compactTitle);
  const seriesSlug = POPMART_SERIES.includes(series) ? popmartSeriesSlug(series) : 'all-series';
  return `/category/pop-mart/${ip}/${seriesSlug}/${item}`;
};

const topGaining = [
  {
    item: 'Labubu Chestnut Cocoa',
    series: 'Exciting Macaron',
    price: '$185.00',
    change: '+$22.50',
    changePct: '+13.8%',
  },
  {
    item: 'Skullpanda The Vision',
    series: 'Image of Reality',
    price: '$45.00',
    change: '+$3.15',
    changePct: '+7.5%',
  },
  {
    item: 'Dimoo Cotton Candy',
    series: 'Dating Series',
    price: '$32.00',
    change: '+$1.80',
    changePct: '+5.9%',
  },
  {
    item: 'Hirono The Ghost',
    series: 'City of Mercy',
    price: '$55.00',
    change: '+$2.50',
    changePct: '+4.7%',
  },
  {
    item: 'Molly Space 100%',
    series: 'Space Molly',
    price: '$40.00',
    change: '+$1.50',
    changePct: '+3.8%',
  },
];

const apiBaseUrl = import.meta.env.TOYCHART_API_URL ?? 'http://localhost:8080';

const popMartFallback: PopMartRow[] = [
  { item: 'Labubu Sea Salt Coconut', series: 'Exciting Macaron', price: '$32.00', soldAt: '--', href: toPopmartItemHref('Labubu Sea Salt Coconut') },
  { item: 'Skullpanda The Warmth', series: 'Image of Reality', price: '$28.00', soldAt: '--', href: toPopmartItemHref('Skullpanda The Warmth') },
  { item: 'Hirono The Crow', series: 'City of Mercy', price: '$25.00', soldAt: '--', href: toPopmartItemHref('Hirono The Crow') },
  { item: 'Labubu Lychee Berry', series: 'Exciting Macaron', price: '$38.00', soldAt: '--', href: toPopmartItemHref('Labubu Lychee Berry') },
  { item: 'Dimoo Rose Knight', series: 'Dating Series', price: '$22.00', soldAt: '--', href: toPopmartItemHref('Dimoo Rose Knight') },
];

let popMartHot: PopMartRow[] = popMartFallback;

try {
  const res = await fetch(`${apiBaseUrl}/category/pop-mart/labubu/hot?limit=5`);

  const payload = await res.json();
  const soldItems: PopmartHotApiItem[] = Array.isArray(payload?.result)
    ? payload.result
    : [];

  if (soldItems.length > 0) {
    popMartHot = soldItems.map((row) => ({
      item: sanitizePopmartTitle(row.item),
      series: row.series || classifyPopmartSeries(row.item),
      price: formatUsd(row.price),
      soldAt: formatSoldAt(row.soldAt),
      href: row.href || toPopmartItemHref(row.item, row.series),
    }));
  }
} catch (_) {
  popMartHot = popMartFallback;
}

const funkoHot = [
  {
    item: 'President Loki (Glow)',
    series: 'Marvel',
    price: '$85.00',
    vol: 210,
  },
  {
    item: 'Eddie Munson',
    series: 'Stranger Things',
    price: '$110.00',
    vol: 185,
  },
  {
    item: 'Spider-Man (Black Suit)',
    series: 'Marvel',
    price: '$45.00',
    vol: 150,
  },
  {
    item: 'Anakin Skywalker (Dark Side)',
    series: 'Star Wars',
    price: '$65.00',
    vol: 132,
  },
  { item: 'Batman (Art Series)', series: 'DC', price: '$35.00', vol: 95 },
];
---

<Layout title="Toychart - Collectible Prices & Market Data">
  <section class="search-section slide-up">
    <div class="container">
      <h1 class="visually-hidden">Collectible Prices and Tracker</h1>
      <div class="search-box glass-panel">
        <h2 class="search-heading">Find Collectible Prices & Values</h2>
        <Search
          className="home-search"
          placeholder="Search for Pop Mart, Funko, LEGO..."
        />
      </div>
    </div>
  </section>

  <section class="market-overview fade-in" style="animation-delay: 0.1s;">
    <div class="container">
      <div class="data-tables-grid">
        <!-- Table 1 -->
        <div class="data-card glass-panel">
          <div class="card-header">
            <h3>Top Gaining Collectibles</h3>
            <a href="/market/gainers" class="text-link">More</a>
          </div>
          <table class="dense-table">
            <thead>
              <tr>
                <th>Item</th>
                <th class="right">Price</th>
                <th class="right text-up">Change</th>
              </tr>
            </thead>
            <tbody>
              {
                topGaining.map((row) => (
                  <tr>
                    <td>
                      <a href="/item/dummy" class="item-link">
                        <span class="item-name">{row.item}</span>
                        <span class="item-meta">{row.series}</span>
                      </a>
                    </td>
                    <td class="right font-bold">{row.price}</td>
                    <td class="right text-up text-sm">
                      {row.change}
                      <br />({row.changePct})
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <!-- Table 2 -->
        <div class="data-card glass-panel">
          <div class="card-header">
            <h3>Hot Pop Mart</h3>
            <a href="/category/pop-mart" class="text-link">More</a>
          </div>
          <table class="dense-table">
            <thead>
              <tr>
                <th>Item</th>
                <th class="right">Price</th>
                <th class="right">Sold At</th>
              </tr>
            </thead>
            <tbody>
              {
                popMartHot.map((row) => {
                  const soldAt = splitSoldAt(row.soldAt);
                  return (
                    <tr>
                      <td>
                        <a href={row.href} class="item-link">
                          <span class="item-name">{row.item}</span>
                          <span class="item-meta">{row.series}</span>
                        </a>
                      </td>
                      <td class="right font-bold">{row.price}</td>
                      <td class="right text-secondary sold-at-cell">
                        {soldAt ? (
                          <>
                            <span class="sold-at-top">{soldAt.top}</span>
                            <span class="sold-at-year">{soldAt.year}</span>
                          </>
                        ) : (
                          row.soldAt
                        )}
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>

        <!-- Table 3 -->
        <div class="data-card glass-panel">
          <div class="card-header">
            <h3>Hot Funko Pops!</h3>
            <a href="/category/funko" class="text-link">More</a>
          </div>
          <table class="dense-table">
            <thead>
              <tr>
                <th>Item</th>
                <th class="right">Price</th>
                <th class="right">30d Vol</th>
              </tr>
            </thead>
            <tbody>
              {
                funkoHot.map((row) => (
                  <tr>
                    <td>
                      <a href="/item/dummy" class="item-link">
                        <span class="item-name">{row.item}</span>
                        <span class="item-meta">{row.series}</span>
                      </a>
                    </td>
                    <td class="right font-bold">{row.price}</td>
                    <td class="right text-secondary">{row.vol}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Search Section */
  .search-section {
    padding: 3rem 0;
  }

  .search-box {
    padding: 2.5rem;
    text-align: center;
    border-top: 4px solid var(--brand-primary);
  }

  .search-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  /* Specific override for the search component in this context */
  :global(.home-search) {
    max-width: 800px !important;
    margin: 0 auto;
  }

  :global(.home-search .search-input-wrapper) {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
  }

  /* Shared Utility Links */
  .text-link {
    color: var(--brand-primary);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .text-link:hover {
    color: var(--brand-accent);
  }

  .text-secondary {
    color: var(--text-secondary);
  }

  .text-tertiary {
    color: var(--text-tertiary);
  }

  .right {
    text-align: right;
  }

  .font-bold {
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
  }

  .text-up {
    color: var(--trend-up);
  }

  .text-down {
    color: var(--trend-down);
  }

  .text-neutral {
    color: var(--text-tertiary);
  }

  .text-sm {
    font-size: 0.8rem;
  }

  /* Market Overview section */
  .market-overview {
    padding: 1rem 0 4rem;
  }

  .data-tables-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .data-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    background: rgba(0, 0, 0, 0.2);
    border-bottom: 1px solid var(--border-color);
  }

  .card-header h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
  }

  .dense-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    background: transparent;
  }

  .dense-table th {
    text-align: left;
    padding: 0.75rem 1.25rem;
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--border-color);
  }

  .dense-table td {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    vertical-align: middle;
  }

  .dense-table tr:last-child td {
    border-bottom: none;
  }

  .dense-table tbody tr:hover td {
    background: rgba(255, 255, 255, 0.02);
  }

  .item-link {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .item-name {
    color: var(--text-primary);
    font-weight: 500;
  }

  .item-link:hover .item-name {
    color: var(--brand-primary);
  }

  .item-meta {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .sold-at-cell {
    white-space: nowrap;
    line-height: 1.15;
    font-variant-numeric: tabular-nums;
  }

  .sold-at-top,
  .sold-at-year {
    display: block;
  }

  .sold-at-year {
    font-size: inherit;
    color: var(--text-tertiary);
  }

  .right {
    text-align: right;
  }

  .font-bold {
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
  }

  .text-up {
    color: var(--trend-up);
  }

  .text-sm {
    font-size: 0.8rem;
  }

  @media (max-width: 1024px) {
    .data-tables-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .data-tables-grid {
      grid-template-columns: 1fr;
    }

    .search-box {
      padding: 1.5rem 1rem;
    }
  }
</style>
