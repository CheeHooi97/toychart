---
import Layout from '../layouts/Layout.astro';
import CollectibleCard from '../components/ui/CollectibleCard.astro';
import TrendBadge from '../components/ui/TrendBadge.astro';

const portfolioStats = {
  totalValue: '$1,245.50',
  totalItems: 12,
  costBasis: '$850.00',
  totalReturn: '+$395.50',
  returnPercent: '+46.5%',
  trend: 'up' as const,
  bestPerformer: {
    name: 'Chestnut Cocoa (Secret)',
    return: '+$169.01',
  },
};

const myItems = [
  {
    id: 'lb-macaron-secret',
    name: 'Chestnut Cocoa (Secret)',
    series: 'Labubu Exciting Macaron',
    price: '$185.00',
    trend: 'up' as const,
    trendValue: '+12.5%',
    imageUrl:
      'https://imagedelivery.net/j3cQhHk0Y2fW12f0X0X0Xw/placeholder-5/public',
    rarity: 'Secret',
  },
  {
    id: 'lb-macaron-sea-salt',
    name: 'Sea Salt Coconut',
    series: 'Labubu Exciting Macaron',
    price: '$32.00',
    trend: 'down' as const,
    trendValue: '-1.5%',
    imageUrl:
      'https://imagedelivery.net/j3cQhHk0Y2fW12f0X0X0Xw/placeholder-6/public',
    rarity: 'Common',
  },
  {
    id: 'sp-image-reality',
    name: 'The Vision',
    series: 'Skullpanda Image Of Reality',
    price: '$45.00',
    trend: 'up' as const,
    trendValue: '+4.2%',
    imageUrl:
      'https://imagedelivery.net/j3cQhHk0Y2fW12f0X0X0Xw/placeholder-4/public',
    rarity: 'Common',
  },
];
---

<Layout title="My Collection Portfolio">
  <div class="container page-layout">
    <header class="portfolio-header slide-up">
      <div class="header-intro">
        <h1 class="page-title">My Collection</h1>
        <p class="text-secondary">
          Track the real-time value of your owned items.
        </p>
      </div>

      <div class="header-actions">
        <button class="btn btn-secondary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
            ></path><polyline points="7 10 12 15 17 10"></polyline><line
              x1="12"
              y1="15"
              x2="12"
              y2="3"></line></svg
          >
          Export CSV
        </button>
        <button class="btn btn-primary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="12" y1="5" x2="12" y2="19"></line><line
              x1="5"
              y1="12"
              x2="19"
              y2="12"></line></svg
          >
          Add Item
        </button>
      </div>
    </header>

    <div class="portfolio-dash fade-in">
      <div class="value-card glass-panel main">
        <span class="card-label">Total Portfolio Value</span>
        <div class="value-display">
          <span class="main-val">{portfolioStats.totalValue}</span>
          <TrendBadge
            trend={portfolioStats.trend}
            value={portfolioStats.returnPercent}
          />
        </div>
        <div class="value-footer">
          <div class="footer-stat">
            <span class="text-tertiary">All-time return</span>
            <span class="text-up font-bold">{portfolioStats.totalReturn}</span>
          </div>
          <div class="footer-stat">
            <span class="text-tertiary">Cost basis</span>
            <span class="text-primary font-bold"
              >{portfolioStats.costBasis}</span
            >
          </div>
        </div>
      </div>

      <div class="stats-grid">
        <div class="value-card glass-panel">
          <span class="card-label">Total Items</span>
          <span class="stat-val">{portfolioStats.totalItems}</span>
          <div class="value-footer outline-top">
            <a href="#" class="text-link">Manage inventory →</a>
          </div>
        </div>
        <div class="value-card glass-panel">
          <span class="card-label">Top Performer</span>
          <span class="stat-val truncate"
            >{portfolioStats.bestPerformer.name}</span
          >
          <div class="value-footer outline-top">
            <span class="text-up font-bold"
              >{portfolioStats.bestPerformer.return}</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="inventory-section fade-in" style="animation-delay: 0.1s;">
      <div class="section-header">
        <h2 class="section-title">Inventory</h2>
        <div class="inventory-controls">
          <input
            type="text"
            class="filter-input glass-panel"
            placeholder="Filter items..."
          />
          <select class="sort-select glass-panel">
            <option>Highest Value</option>
            <option>Lowest Value</option>
            <option>Recently Added</option>
          </select>
        </div>
      </div>

      <div class="list-container glass-panel">
        <table class="inventory-table">
          <thead>
            <tr>
              <th class="col-image">Item</th>
              <th class="col-name">Title / Details</th>
              <th class="col-price right">Purchase Price</th>
              <th class="col-price right">Current Value</th>
              <th class="col-price right">Return</th>
              <th class="col-action right">Actions</th>
            </tr>
          </thead>
          <tbody>
            {
              myItems.map((item) => (
                <tr>
                  <td class="col-image">
                    <a href={`/item/${item.id}`} class="thumbnail">
                      {item.imageUrl ? (
                        <img src={item.imageUrl} alt={item.name} />
                      ) : (
                        <div class="thumb-fallback">🧸</div>
                      )}
                    </a>
                  </td>
                  <td class="col-name">
                    <a href={`/item/${item.id}`} class="item-title">
                      {item.name}
                    </a>
                    <p class="item-series">{item.series}</p>
                  </td>
                  <td class="col-price right">
                    <span class="price-val text-secondary">$25.00</span>
                  </td>
                  <td class="col-price right">
                    <span class="price-val font-bold">{item.price}</span>
                  </td>
                  <td class="col-price right">
                    <div class="price-trend-wrap">
                      <span
                        class={`trend-val font-bold ${item.trend === 'up' ? 'text-up' : item.trend === 'down' ? 'text-down' : 'text-neutral'}`}
                      >
                        {item.trend === 'up'
                          ? '+$' +
                            (
                              parseFloat(item.price.replace('$', '')) - 25
                            ).toFixed(2)
                          : '--'}
                      </span>
                      <span
                        class={`trend-sm ${item.trend === 'up' ? 'text-up' : item.trend === 'down' ? 'text-down' : 'text-neutral'}`}
                      >
                        {item.trendValue}
                      </span>
                    </div>
                  </td>
                  <td class="col-action right">
                    <button
                      class="action-btn text-secondary"
                      aria-label="Edit Item"
                    >
                      Edit
                    </button>
                    <button
                      class="action-btn text-down"
                      aria-label="Remove Item"
                    >
                      Remove
                    </button>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-layout {
    padding-top: 3rem;
  }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 2.5rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .text-secondary {
    color: var(--text-secondary);
  }

  .text-tertiary {
    color: var(--text-tertiary);
  }

  .text-primary {
    color: var(--text-primary);
  }

  .text-up {
    color: var(--trend-up);
  }

  .font-bold {
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
  }

  .text-link {
    color: var(--brand-primary);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .text-link:hover {
    color: var(--brand-accent);
  }

  .header-actions {
    display: flex;
    gap: 1rem;
  }

  .btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--brand-primary);
    color: white;
    border: none;
    box-shadow: 0 4px 14px 0 rgba(59, 130, 246, 0.39);
  }

  .btn-primary:hover {
    background: var(--brand-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.23);
  }

  .btn-secondary {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background: var(--bg-tertiary);
    border-color: var(--text-secondary);
  }

  .portfolio-dash {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .value-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .value-card.main {
    justify-content: space-between;
  }

  .card-label {
    font-size: 0.9rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    display: block;
  }

  .value-display {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .main-val {
    font-family: 'Outfit', sans-serif;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    text-shadow: 0 0 30px rgba(59, 130, 246, 0.15);
  }

  .stat-val {
    font-family: 'Outfit', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .truncate {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .stats-grid {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 1.5rem;
  }

  .value-footer {
    display: flex;
    gap: 2rem;
  }

  .value-footer.outline-top {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1rem;
    margin-top: auto;
  }

  .footer-stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-stat .text-tertiary {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer-stat .font-bold {
    font-size: 1.1rem;
  }

  .inventory-section {
    margin-top: 2rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
  }

  .section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
  }

  .inventory-controls {
    display: flex;
    gap: 1rem;
  }

  .filter-input {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    outline: none;
    min-width: 200px;
  }

  .filter-input:focus {
    border-color: var(--brand-primary);
  }

  .sort-select {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    padding: 0.5rem 2rem 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    appearance: none;
    cursor: pointer;
    outline: none;
  }

  /* Table Styles */
  .list-container {
    overflow-x: auto;
    border-radius: 8px;
  }

  .inventory-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
  }

  .inventory-table th {
    text-align: left;
    padding: 1rem 1.25rem;
    background: rgba(0, 0, 0, 0.2);
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--border-color);
  }

  .inventory-table td {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    vertical-align: middle;
  }

  .inventory-table tbody tr:hover td {
    background: rgba(255, 255, 255, 0.02);
  }

  .inventory-table tr:last-child td {
    border-bottom: none;
  }

  .col-image {
    width: 70px;
  }
  .col-name {
    width: 35%;
  }
  .col-price {
    width: 140px;
  }
  .col-action {
    width: 120px;
  }

  .right {
    text-align: right;
  }

  .thumbnail {
    display: block;
    width: 54px;
    height: 54px;
    background: var(--bg-secondary);
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .item-title {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
    display: block;
    margin-bottom: 0.2rem;
  }

  .item-title:hover {
    color: var(--brand-primary);
  }

  .item-series {
    font-size: 0.8rem;
    color: var(--text-tertiary);
  }

  .price-trend-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
  }

  .trend-sm {
    font-size: 0.75rem;
    font-weight: 500;
  }

  .action-btn {
    background: transparent;
    border: none;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    margin-left: 0.75rem;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .action-btn:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .text-down {
    color: var(--trend-down);
  }

  @media (max-width: 900px) {
    .portfolio-dash {
      grid-template-columns: 1fr;
    }

    .portfolio-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .inventory-controls {
      width: 100%;
    }

    .filter-input,
    .sort-select {
      flex: 1;
    }
  }
</style>
