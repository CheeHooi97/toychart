---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Track your favorite Pop Mart and Funko collectibles. Discover series, market prices, and manage your portfolio.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | toychart</title>
  </head>
  <body>
    <!-- Abstract ambient background -->
    <div class="ambient-bg">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
    </div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .ambient-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.15;
    animation: pulse 10s infinite alternate;
  }

  .glow-1 {
    background: var(--brand-primary);
    top: -200px;
    left: -100px;
  }

  .glow-2 {
    background: var(--brand-accent);
    bottom: 20%;
    right: -200px;
    animation-delay: -5s;
  }

  @keyframes pulse {
    0% {
      transform: scale(1) translate(0, 0);
      opacity: 0.1;
    }
    50% {
      transform: scale(1.2) translate(50px, -50px);
      opacity: 0.15;
    }
    100% {
      transform: scale(0.9) translate(-50px, 50px);
      opacity: 0.1;
    }
  }

  main {
    min-height: calc(100vh - 160px); /* header + footer rough height */
    padding-bottom: 4rem;
  }
</style>
