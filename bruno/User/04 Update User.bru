meta {
  name: Update User
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/v1/user/update/:id
  body: multipartForm
  auth: none
}

params:path {
  id: {{userId}}
}

headers {
  Authorization: Bearer {{authToken}}
}

body:multipart-form {
  username: bruno-user-updated
  photo: @file({{photoPath}})
}
